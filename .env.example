# ============================================================
# BigBounce Research Environment — API Keys
# ============================================================
# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and will never be committed.
#
# HYBRID MODEL:
#   - Keys here are used directly by local research scripts
#   - Hubify Convex backend has its own keys for workspace agents
#   - This keeps BigBounce research independent of Hubify infra
# ============================================================

# --- LLM / Deep Reasoning -------------------------------------------
# Used by research agents for mathematical verification, writing,
# literature synthesis, and deep reasoning tasks.

# Anthropic Claude (scientific writing, argument structuring)
ANTHROPIC_API_KEY=

# OpenAI GPT (general reasoning, xhigh tier)
OPENAI_API_KEY=

# Google Gemini (Deep Think — multimodal reasoning, data + math)
GOOGLE_AI_API_KEY=

# DeepSeek R1 (math rigor, catching sign errors in tensor derivations)
# Note: R1 may return empty content when reasoning chain uses all tokens
DEEPSEEK_API_KEY=

# xAI Grok (fast reasoning, alternative perspective)
XAI_API_KEY=

# OpenRouter (multi-model routing — fallback/comparison)
OPENROUTER_API_KEY=

# --- Science & Literature APIs --------------------------------------

# NASA ADS (Astrophysics Data System — literature search)
# Get key at: https://ui.adsabs.harvard.edu/user/settings/token
NASA_ADS_API_KEY=

# Semantic Scholar (paper discovery, citation graphs)
# Get key at: https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# arXiv — no key needed (public API), but rate-limited to 1 req/3s

# --- Data & Compute -------------------------------------------------

# Hugging Face (access to MMU 100TB dataset, gated models)
# Get token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# --- Computation & Verification -------------------------------------

# Perplexity (web-grounded LLM — live literature search)
# API is OpenAI-compatible: POST https://api.perplexity.ai/chat/completions
PERPLEXITY_API_KEY=

# Wolfram Alpha (exact computation, equation verification)
# Get AppID at: https://developer.wolframalpha.com/
# Free tier: 2,000 queries/month
WOLFRAM_ALPHA_APP_ID=

# --- Web Research & Scraping ----------------------------------------

# Firecrawl (structured web scraping for research)
FIRECRAWL_API_KEY=

# --- GPU Cloud (RunPod) -----------------------------------------------

# RunPod API key for pod management (create/stop/start)
# Get key at: https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=

# --- Optional / Future ----------------------------------------------
# These services are primarily web-based but may offer API access.
# Uncomment and fill in as needed.

# CONSENSUS_API_KEY=        # Waitlisted — join at consensus.app
# TRINKA_API_KEY=            # Enterprise only — developer.trinka.ai

# --- Local Config (not secrets) -------------------------------------

# Default model for research tasks (claude-opus-4-6, gpt-5.2, gemini-deep-think, deepseek-r1)
DEFAULT_RESEARCH_MODEL=claude-opus-4-6

# Max tokens for reasoning chains
MAX_REASONING_TOKENS=16384

# Research output directory
RESEARCH_OUTPUT_DIR=./research/outputs
